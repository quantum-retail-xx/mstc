function convert(datev)
{
	a = "";
	a2 = ""
	x = datev;
	y = x.split("-");

	for (i=0; i<(y.length-2); i++)
		a = a + eval("y[" +i+ "]") + "/";
	a = a + y[y.length-2] +" ";

	//Now second part
	b = y[y.length-1];
	c = b.split(".");

	for (i=0; i<(c.length-1); i++)
		a2 = a2 + eval("c[" +i+ "]") + ":";
	a2 = a2 + c[c.length-1];
	return(a + a2);
}

